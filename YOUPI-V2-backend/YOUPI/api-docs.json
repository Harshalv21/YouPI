Token":{"type":"string"}}},"MpinSetupRequest":{"required":["mpin"],"type":"object","properties":{"mpin":{"type":"string"}}},"MpinVerifyRequest":{"required":["mobile","mpin"],"type":"object","properties":{"mobile":{"type":"string"},"mpin":{"type":"string"}}},"SendOtpRequest":{"required":["mobile"],"type":"object","properties":{"mobile":{"type":"string"}}},"VerifyOtpRequest":{"required":["mobile","otp"],"type":"object","properties":{"mobile":{"type":"string"},"otp":{"type":"string"},"deviceId":{"type":"string"}}},"CreatePaymentOrderRequest":{"required":["amount","idempotencyKey","purpose"],"type":"object","properties":{"amount":{"type":"number"},"purpose":{"type":"string","enum":["RECHARGE","SMART_DEPOSIT","FD_OPEN","LOAN_EMI","GOLD_BUY","WALLET_TOPUP"]},"referenceId":{"type":"string","format":"uuid"},"idempotencyKey":{"type":"string"}}},"VerifyPaymentRequest":{"required":["razorpayOrderId","razorpayPaymentId","razorpaySignature"],"type":"object","properties":{"razorpayPaymentId":{"type":"string"},"razorpayOrderId":{"type":"string"},"razorpaySignature":{"type":"string"}}},"TransferRequest":{"required":["amount","idempotencyKey","recipientMobile","walletType"],"type":"object","properties":{"recipientMobile":{"type":"string"},"amount":{"type":"number"},"walletType":{"type":"string"},"description":{"type":"string"},"idempotencyKey":{"type":"string"}}},"BnplStep1Request":{"required":["employmentType","monthlyIncome"],"type":"object","properties":{"employmentType":{"type":"string"},"monthlyIncome":{"type":"number"}}},"BnplStep2Request":{"required":["cibilConsent"],"type":"object","properties":{"cibilConsent":{"type":"boolean"}}},"BnplStep3Request":{"required":["tcConsent"],"type":"object","properties":{"tcConsent":{"type":"boolean"}}},"LoanStep1Request":{"required":["dateOfBirth","fullName","panNumber"],"type":"object","properties":{"fullName":{"type":"string"},"dateOfBirth":{"type":"string","format":"date"},"panNumber":{"type":"string"},"fathersName":{"type":"string"},"address":{"type":"string"},"pincode":{"type":"string"},"city":{"type":"string"},"state":{"type":"string"}}},"LoanStep2Request":{"required":["cibilConsent","employmentType"],"type":"object","properties":{"employmentType":{"type":"string"},"employerName":{"type":"string"},"monthlyIncome":{"type":"number"},"cibilConsent":{"type":"boolean"}}},"LoanStep3Request":{"required":["requestedAmount","tenureMonths"],"type":"object","properties":{"requestedAmount":{"type":"number"},"tenureMonths":{"type":"integer","format":"int32"}}}},"securitySchemes":{"bearerAuth":{"type":"http","description":"MPIN JWT token from /api/v1/auth/mpin/verify","scheme":"bearer","bearerFormat":"JWT"},"firebaseAuth":{"type":"http","description":"Firebase Auth ID token for user identification","scheme":"bearer","bearerFormat":"Firebase ID Token"}}}}