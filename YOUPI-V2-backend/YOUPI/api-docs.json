{"openapi":"3.0.1","info":{"title":"YouPI V2 API","version":"2.0.0"},"servers":[{"url":"http://localhost:8082/api","description":"Local HTTP"},{"url":"https://youpi-api-887162129478.asia-south1.run.app/api","description":"Production (Cloud Run)"},{"url":"/api","description":"Relative to current host"}],"security":[{"bearerAuth":[]}],"tags":[{"name":"Auth","description":"OTP login, MPIN setup/verify, token management"},{"name":"User","description":"User profile & KYC management"},{"name":"Recharge","description":"Mobile recharge plans, orders, EMI"},{"name":"Payment","description":"Razorpay payment orders & webhooks"},{"name":"Smart Saver","description":"Deposit-backed credit facility"},{"name":"Gold","description":"Digital gold buy/sell & holdings"},{"name":"Fixed Deposit","description":"FD listing & management"},{"name":"BNPL","description":"Buy Now Pay Later application & accounts"},{"name":"Loan","description":"Personal loan application, EMI schedule"},{"name":"Wallet","description":"NBFC wallet, P2P transfer, ledger"},{"name":"Admin","description":"Admin dashboard, user management"}],"paths":{"/v1/recharge/history":{"get":{"tags":["Recharge"],"summary":"Get recharge history","description":"Returns paginated recharge order history for the authenticated user.","operationId":"getRechargeHistory","parameters":[{"name":"page","in":"query","description":"Page number (0-based)","schema":{"type":"string"}}],"responses":{"200":{"description":"List of past recharge orders"}}}},"/v1/recharge/order":{"post":{"tags":["Recharge"],"summary":"Create recharge order","description":"Creates a new recharge order with optional EMI payment mode. Returns Razorpay order ID.","operationId":"createRechargeOrder","requestBody":{"content":{"*/*":{"schema":{"$ref":"#/components/schemas/CreateRechargeRequest"}}}},"responses":{"201":{"description":"Order created with Razorpay order ID"}}}},"/v1/recharge/order/{orderId}":{"get":{"tags":["Recharge"],"summary":"Get recharge order status","description":"Returns the current status of a recharge order including A1Topup processing status.","operationId":"getOrderStatus","parameters":[{"name":"orderId","in":"query","description":"UUID of the recharge order","required":true,"schema":{"type":"string"}}],"responses":{"200":{"description":"Order status details"}}}},"/v1/recharge/order/{orderId}/confirm":{"post":{"tags":["Recharge"],"summary":"Confirm recharge after payment","description":"Verifies Razorpay payment signature, marks the recharge as successful, and auto-invests a small percentage of the recharge amount into gold. Gold-invest failure does not fail the recharge — check goldWarning in the response.","operationId":"confirmRechargeOrder","parameters":[{"name":"orderId","in":"query","description":"UUID of the recharge order","required":true,"schema":{"type":"string"}}],"requestBody":{"content":{"*/*":{"schema":{"$ref":"#/components/schemas/ConfirmRechargeRequest"}}}},"responses":{"200":{"description":"Recharge confirmed, with gold auto-invest outcome"}}}},"/v1/recharge/plans":{"get":{"tags":["Recharge"],"summary":"Fetch recharge plans","description":"Fetches recharge plans from mPlan API for a given operator and circle. Results are cached for 30 minutes.","operationId":"fetchPlans","parameters":[{"name":"operator","in":"query","description":"Telecom operator (e.g. JIO, AIRTEL, VI)","schema":{"type":"string"}},{"name":"circle","in":"query","description":"Service circle (e.g. UP-East, Delhi)","schema":{"type":"string"}}],"responses":{"200":{"description":"List of recharge plans"}}}},"/v1/fd/create":{"post":{"tags":["Gold FD"],"summary":"Create Gold FD","description":"Creates a new Gold Fixed Deposit on Augmont.","operationId":"createFd","responses":{"201":{"description":"Gold FD created"}}}},"/v1/fd/list":{"get":{"tags":["Fixed Deposit"],"summary":"List fixed deposits","description":"Returns all legacy fixed deposits for the authenticated user.","operationId":"listFixedDeposits","responses":{"200":{"description":"List of FDs"}}}},"/v1/fd/preview":{"post":{"tags":["Gold FD"],"summary":"Preview Gold FD interest","description":"Calculates expected interest and maturity for a Gold FD based on weight, tenure, and scheme.","operationId":"previewFd","responses":{"200":{"description":"FD preview"}}}},"/v1/fd/schemes":{"get":{"tags":["Gold FD"],"summary":"List Gold FD schemes","description":"Returns available Gold FD schemes from Augmont.","operationId":"getFdSchemes","responses":{"200":{"description":"FD schemes"}}}},"/v1/fd/{id}":{"get":{"tags":["Gold FD"],"summary":"Get Gold FD details","description":"Returns details of a specific Gold FD by its Augmont ID.","operationId":"getFdDetail","responses":{"200":{"description":"FD details"}}}},"/v1/fd/{id}/close":{"post":{"tags":["Gold FD"],"summary":"Pre-close Gold FD","description":"Initiates early closure of a Gold FD.","operationId":"closeFd","responses":{"200":{"description":"FD close result"}}}},"/v1/gold/buy":{"post":{"tags":["Gold"],"summary":"Buy digital gold/silver","description":"Purchases digital gold/silver for the given amount in INR via Augmont. Idempotent via idempotencyKey. Uses locked blockId and rate.","operationId":"buyGold","responses":{"201":{"description":"Gold purchase confirmation"}}}},"/v1/gold/history":{"get":{"tags":["Gold"],"summary":"Get price history","description":"Returns historical gold/silver price data for chart rendering. Supports durations: 1d, 1w, 1m, 3m, 6m, 1y.","operationId":"getPriceHistory","responses":{"200":{"description":"Price history"}}}},"/v1/gold/holdings":{"get":{"tags":["Gold"],"summary":"Get gold holdings","description":"Returns the user's total digital gold holdings in grams and current INR value.","operationId":"getGoldHoldings","responses":{"200":{"description":"Gold holdings"}}}},"/v1/gold/kyc":{"get":{"tags":["Gold"],"summary":"Get Augmont KYC status","description":"Returns the user's KYC verification status on Augmont.","operationId":"getKycStatus","responses":{"200":{"description":"KYC status"}}}},"/v1/gold/passbook":{"get":{"tags":["Gold"],"summary":"Get Augmont passbook","description":"Returns the user's real gold/silver balance directly from Augmont.","operationId":"getPassbook","responses":{"200":{"description":"Augmont passbook"}}}},"/v1/gold/price":{"get":{"tags":["Gold"],"summary":"Get live gold & silver rates","description":"Returns live gold/silver buy+sell rates from Augmont API. Cached for 35 seconds. Returns blockId needed for buy/sell.","operationId":"getGoldPrice","responses":{"200":{"description":"Current rates with blockId"}}}},"/v1/gold/products":{"get":{"tags":["Gold"],"summary":"List physical gold products","description":"Returns available physical gold/silver products (coins, bars) for redemption.","operationId":"getProducts","responses":{"200":{"description":"Product list"}}}},"/v1/gold/sell":{"post":{"tags":["Gold"],"summary":"Sell digital gold/silver","description":"Sells digital gold/silver by grams via Augmont. Payout to user's bank account.","operationId":"sellGold","responses":{"201":{"description":"Gold sell confirmation"}}}},"/v1/gold/transactions":{"get":{"tags":["Gold"],"summary":"Get gold transaction history","description":"Returns the user's gold buy/sell transaction history.","operationId":"getTransactions","responses":{"200":{"description":"Transaction list"}}}},"/v1/gold/user":{"post":{"tags":["Gold"],"summary":"Create Augmont user mapping","description":"Creates a user on Augmont and maps them to the YouPI user. Must be called before buy/sell.","operationId":"createAugmontUser","responses":{"201":{"description":"User mapping created"}}}},"/v1/user/kyc/aadhaar/otp":{"post":{"tags":["User"],"summary":"Initiate Aadhaar OTP","description":"Sends an OTP to the Aadhaar-linked mobile for e-KYC.","operationId":"initiateAadhaarOtp","requestBody":{"content":{"*/*":{"schema":{"$ref":"#/components/schemas/AadhaarOtpRequest"}}}},"responses":{"200":{"description":"Aadhaar OTP sent"}}}},"/v1/user/kyc/aadhaar/verify":{"post":{"tags":["User"],"summary":"Verify Aadhaar OTP","description":"Verifies the Aadhaar OTP and moves KYC to AADHAAR_DONE.","operationId":"verifyAadhaar","requestBody":{"content":{"*/*":{"schema":{"$ref":"#/components/schemas/AadhaarVerifyRequest"}}}},"responses":{"200":{"description":"Aadhaar verified"}}}},"/v1/user/kyc/pan/verify":{"post":{"tags":["User"],"summary":"Verify PAN card","description":"Verifies the PAN number via Karza API, moves KYC to PAN_DONE.","operationId":"verifyPan","requestBody":{"content":{"*/*":{"schema":{"$ref":"#/components/schemas/PanVerifyRequest"}}}},"responses":{"200":{"description":"PAN verified"}}}},"/v1/user/kyc/selfie":{"post":{"tags":["User"],"summary":"Upload selfie for face match","description":"Uploads a selfie (base64) for face-match verification against Aadhaar photo.","operationId":"uploadSelfie","requestBody":{"content":{"*/*":{"schema":{"$ref":"#/components/schemas/SelfieUploadRequest"}}}},"responses":{"200":{"description":"Selfie verified"}}}},"/v1/user/kyc/status":{"get":{"tags":["User"],"summary":"Get KYC status","description":"Returns the current KYC verification status and step.","operationId":"getKycStatus_1","responses":{"200":{"description":"KYC status"}}}},"/v1/user/profile":{"get":{"tags":["User"],"summary":"Get user profile","description":"Fetches the authenticated user's profile data.","operationId":"getProfile","responses":{"200":{"description":"User profile"}}},"put":{"tags":["User"],"summary":"Update user profile","description":"Updates the user's name, email, date of birth.","operationId":"updateProfile","requestBody":{"content":{"*/*":{"schema":{"$ref":"#/components/schemas/UpdateProfileRequest"}}}},"responses":{"200":{"description":"Updated profile"}}}},"/v1/admin/dashboard":{"get":{"tags":["Admin"],"summary":"Admin dashboard","description":"Returns dashboard statistics: total users, KYC count, recharge count, etc. Admin only.","operationId":"getDashboard","responses":{"200":{"description":"Dashboard statistics"}}}},"/v1/admin/users":{"get":{"tags":["Admin"],"summary":"List all users","description":"Returns a paginated list of all users. Admin only.","operationId":"listUsers","parameters":[{"name":"page","in":"query","description":"Page number (0-based)","schema":{"type":"string"}}],"responses":{"200":{"description":"Paginated user list"}}}},"/v1/admin/users/{userId}":{"get":{"tags":["Admin"],"summary":"Get user details","description":"Returns detailed information for a specific user. Admin only.","operationId":"getUserDetails","parameters":[{"name":"userId","in":"query","description":"UUID of the user","required":true,"schema":{"type":"string"}}],"responses":{"200":{"description":"User details"}}}},"/v1/admin/users/{userId}/active":{"put":{"tags":["Admin"],"summary":"Toggle user active status","description":"Activates or deactivates a user account. Admin only.","operationId":"toggleUserActive","parameters":[{"name":"userId","in":"query","description":"UUID of the user","required":true,"schema":{"type":"string"}}],"responses":{"200":{"description":"Updated user status"}}}},"/v1/admin/users/{userId}/type":{"put":{"tags":["Admin"],"summary":"Update user type","description":"Changes a user's type (NORMAL, SMART_SAVER, ADMIN). Admin only.","operationId":"updateUserType","parameters":[{"name":"userId","in":"query","description":"UUID of the user","required":true,"schema":{"type":"string"}}],"responses":{"200":{"description":"Updated user"}}}},"/v1/auth/firebase/verify":{"post":{"tags":["Auth"],"summary":"Verify Firebase ID token","description":"Verifies a Firebase phone-auth ID token and issues access/refresh tokens. This is the endpoint the Flutter app actually calls after Firebase OTP verification.","operationId":"verifyFirebaseToken","requestBody":{"content":{"*/*":{"schema":{"$ref":"#/components/schemas/FirebaseVerifyRequest"}}}},"responses":{"200":{"description":"Firebase token verified, tokens issued"}}}},"/v1/auth/logout":{"post":{"tags":["Auth"],"summary":"Logout","description":"Revokes the refresh token and logs out the user.","operationId":"logout","requestBody":{"content":{"*/*":{"schema":{"$ref":"#/components/schemas/RefreshTokenRequest"}}}},"responses":{"200":{"description":"Logged out successfully"}}}},"/v1/auth/mpin/setup":{"post":{"tags":["Auth"],"summary":"Setup MPIN","description":"Sets a 4-digit MPIN for the authenticated user. Requires Bearer token.","operationId":"setupMpin","requestBody":{"content":{"*/*":{"schema":{"$ref":"#/components/schemas/MpinSetupRequest"}}}},"responses":{"200":{"description":"MPIN set successfully"}}}},"/v1/auth/mpin/verify":{"post":{"tags":["Auth"],"summary":"Verify MPIN","description":"Verifies the MPIN and issues short-lived access + refresh tokens.","operationId":"verifyMpin","requestBody":{"content":{"*/*":{"schema":{"$ref":"#/components/schemas/MpinVerifyRequest"}}}},"responses":{"200":{"description":"MPIN verified, tokens issued"}}}},"/v1/auth/otp/send":{"post":{"tags":["Auth"],"summary":"Send OTP to mobile","description":"Sends a 6-digit OTP to the given mobile number for login/registration.","operationId":"sendOtp","requestBody":{"content":{"*/*":{"schema":{"$ref":"#/components/schemas/SendOtpRequest"}}}},"responses":{"200":{"description":"OTP sent successfully"}}}},"/v1/auth/otp/verify":{"post":{"tags":["Auth"],"summary":"Verify OTP","description":"Verifies the OTP and returns Firebase custom token + access/refresh tokens.","operationId":"verifyOtp","requestBody":{"content":{"*/*":{"schema":{"$ref":"#/components/schemas/VerifyOtpRequest"}}}},"responses":{"200":{"description":"OTP verified, tokens issued"}}}},"/v1/auth/token/refresh":{"post":{"tags":["Auth"],"summary":"Refresh access token","description":"Uses a valid refresh token to get a new access token.","operationId":"refreshToken","requestBody":{"content":{"*/*":{"schema":{"$ref":"#/components/schemas/RefreshTokenRequest"}}}},"responses":{"200":{"description":"New access token issued"}}}},"/v1/payment/order":{"post":{"tags":["Payment"],"summary":"Create Razorpay order","description":"Creates a Razorpay payment order for the given purpose and amount.","operationId":"createPaymentOrder","requestBody":{"content":{"*/*":{"schema":{"$ref":"#/components/schemas/CreatePaymentOrderRequest"}}}},"responses":{"201":{"description":"Razorpay order created"}}}},"/v1/payment/verify":{"post":{"tags":["Payment"],"summary":"Verify Razorpay payment","description":"Verifies the Razorpay payment signature (HMAC-SHA256) and marks as captured.","operationId":"verifyPayment","requestBody":{"content":{"*/*":{"schema":{"$ref":"#/components/schemas/VerifyPaymentRequest"}}}},"responses":{"200":{"description":"Payment verified"}}}},"/webhooks/razorpay":{"post":{"tags":["Payment"],"summary":"Razorpay webhook handler","description":"Receives Razorpay webhook events. No authentication required. Uses HMAC signature verification.","operationId":"razorpayWebhook","responses":{"200":{"description":"Webhook processed"}}}},"/v1/wallet/balance":{"get":{"tags":["Wallet"],"summary":"Get wallet balances","description":"Returns all wallet balances (NBFC, Smart Saver, Gold, FD Collateral) for the user.","operationId":"getWalletBalance","responses":{"200":{"description":"All wallet balances"}}}},"/v1/wallet/ledger":{"get":{"tags":["Wallet"],"summary":"Get wallet ledger","description":"Returns the double-entry ledger (transaction history) for a specific wallet.","operationId":"getWalletLedger","parameters":[{"name":"type","in":"query","description":"Wallet type: NBFC, SMART_SAVER, GOLD, FD_COLLATERAL","schema":{"type":"string"}},{"name":"page","in":"query","description":"Page number (0-based)","schema":{"type":"string"}}],"responses":{"200":{"description":"Ledger entries"}}}},"/v1/wallet/transfer":{"post":{"tags":["Wallet"],"summary":"P2P wallet transfer","description":"Transfers funds from your NBFC wallet to another user by mobile number. Idempotent.","operationId":"p2pTransfer","requestBody":{"content":{"*/*":{"schema":{"$ref":"#/components/schemas/TransferRequest"}}}},"responses":{"200":{"description":"Transfer successful"}}}},"/v1/smart-saver/balance":{"get":{"tags":["Smart Saver"],"summary":"Get Smart Saver balance","description":"Returns the Smart Saver allocation: deposit, collateral, credit limit, used/available credit.","operationId":"getSmartSaverBalance","responses":{"200":{"description":"Smart Saver allocation details"}}}},"/v1/smart-saver/deposit":{"post":{"tags":["Smart Saver"],"summary":"Add deposit","description":"Adds a deposit amount to the Smart Saver allocation, increasing the credit limit by 80%.","operationId":"addSmartSaverDeposit","responses":{"200":{"description":"Deposit added, new allocation returned"}}}},"/v1/bnpl/apply/step1":{"post":{"tags":["BNPL"],"summary":"BNPL Apply — Step 1: Personal details","description":"Submits personal details (employment type, income). Saved to Redis session (30 min TTL).","operationId":"bnplStep1","requestBody":{"content":{"*/*":{"schema":{"$ref":"#/components/schemas/BnplStep1Request"}}}},"responses":{"200":{"description":"Step 1 saved to session"}}}},"/v1/bnpl/apply/step2":{"post":{"tags":["BNPL"],"summary":"BNPL Apply — Step 2: CIBIL consent","description":"Submits CIBIL consent. Triggers credit bureau check and auto-decision.","operationId":"bnplStep2","requestBody":{"content":{"*/*":{"schema":{"$ref":"#/components/schemas/BnplStep2Request"}}}},"responses":{"200":{"description":"CIBIL consent recorded"}}}},"/v1/bnpl/apply/step3":{"post":{"tags":["BNPL"],"summary":"BNPL Apply — Step 3: T&C acceptance","description":"Accepts terms and conditions. Submits final application for auto-decisioning.","operationId":"bnplStep3","requestBody":{"content":{"*/*":{"schema":{"$ref":"#/components/schemas/BnplStep3Request"}}}},"responses":{"200":{"description":"Application submitted with decision"}}}},"/v1/bnpl/status":{"get":{"tags":["BNPL"],"summary":"Get BNPL status","description":"Returns the user's BNPL application status, account limits, and available credit.","operationId":"getBnplStatus","responses":{"200":{"description":"BNPL status and limits"}}}},"/v1/loan/apply/step1":{"post":{"tags":["Loan"],"summary":"Loan Apply — Step 1: Personal info","description":"Submits personal info (name, DOB, PAN, address). Saved to Redis session.","operationId":"loanStep1","requestBody":{"content":{"*/*":{"schema":{"$ref":"#/components/schemas/LoanStep1Request"}}}},"responses":{"200":{"description":"Step 1 saved"}}}},"/v1/loan/apply/step2":{"post":{"tags":["Loan"],"summary":"Loan Apply — Step 2: Employment & documents","description":"Submits employment details, income, and KYC documents.","operationId":"loanStep2","requestBody":{"content":{"*/*":{"schema":{"$ref":"#/components/schemas/LoanStep2Request"}}}},"responses":{"200":{"description":"Step 2 saved"}}}},"/v1/loan/apply/step3":{"post":{"tags":["Loan"],"summary":"Loan Apply — Step 3: Final submission","description":"Submits CIBIL consent and loan amount. Triggers auto-decision and EMI calculation.","operationId":"loanStep3","requestBody":{"content":{"*/*":{"schema":{"$ref":"#/components/schemas/LoanStep3Request"}}}},"responses":{"200":{"description":"Application decision"}}}},"/v1/loan/emi/calculate":{"get":{"tags":["Loan"],"summary":"EMI calculator","description":"Calculates monthly EMI for given principal, rate, and tenure using reducing balance formula.","operationId":"calculateEmi","parameters":[{"name":"principal","in":"query","description":"Loan principal amount","schema":{"type":"string"}},{"name":"rate","in":"query","description":"Annual interest rate (%)","schema":{"type":"string"}},{"name":"tenure","in":"query","description":"Tenure in months","schema":{"type":"string"}}],"responses":{"200":{"description":"EMI calculation result"}}}},"/v1/loan/emi/schedule":{"get":{"tags":["Loan"],"summary":"Get EMI schedule","description":"Returns the full EMI schedule for an active loan account.","operationId":"getEmiSchedule","responses":{"200":{"descrip